            this.elements.closeConfirmModal.addEventListener('click', () => this.elements.confirmModal.classList.remove('active'));
            this.elements.confirmOkBtn.addEventListener('click', () => {
                if (this.pendingConfirmCallback) {
                    this.pendingConfirmCallback();
                    this.pendingConfirmCallback = null;
                }
                this.elements.confirmModal.classList.remove('active');
            });
            this.elements.closeReportResultModal.addEventListener('click', () => this.elements.reportResultModal.classList.remove('active'));
            this.elements.closeReportResultBtn.addEventListener('click', () => this.elements.reportResultModal.classList.remove('active'));
            this.elements.exportReportExcelBtn.addEventListener('click', () => this.exportReportToExcel());
        }

        showConfirmDialog(message, callback) {
            this.elements.confirmMessage.innerText = message;
            this.pendingConfirmCallback = callback;
            this.elements.confirmModal.classList.add('active');
        }

        createDocBlock(typeInfo, data = null, onRemove) {
            const div = createSafeElement('div', { class: 'org-doc-item', 'data-doc-id': typeInfo.id });
            const titleDiv = createSafeElement('div', { class: 'doc-title' }, typeInfo.title);
            const removeIcon = createSafeElement('i', { class: 'fas fa-times-circle remove-doc' });
            titleDiv.appendChild(removeIcon);
            div.appendChild(titleDiv);
            if (typeInfo.hasDuration) {
                const durRow = createSafeElement('div', { class: 'duration-row' });
                const dateInp = createSafeElement('input', { type: 'date', class: 'doc-date' });
                const durSel = createSafeElement('select', { class: 'doc-duration' });
                for (let y of [1,2,3,4,5]) {
                    const opt = createSafeElement('option', { value: y.toString() }, `${y} год`);
                    durSel.appendChild(opt);
                }
                const endSpan = createSafeElement('span', { class: 'doc-end-display' });
                durRow.appendChild(dateInp); durRow.appendChild(durSel); durRow.appendChild(endSpan);
                div.appendChild(durRow);
                const updateEnd = () => {
                    if (dateInp.value) {
                        const end = new Date(dateInp.value);
                        end.setFullYear(end.getFullYear()+parseInt(durSel.value));
                        endSpan.textContent = `Окончание: ${end.toISOString().split('T')[0]}`;
                    } else endSpan.textContent = '';
                };
                dateInp.addEventListener('change', updateEnd);
                durSel.addEventListener('change', updateEnd);
                if (data) { dateInp.value = data.date || ''; durSel.value = data.duration || '1'; if (data.date) updateEnd(); }
            }
            const attach = createSafeElement('div', { class: 'file-attach' });
            const attachSpan = createSafeElement('span', {}, 'Прикрепить файл');
            const attachIcon = createSafeElement('i', { class: 'fas fa-file-pdf' });
            const fileInput = createSafeElement('input', { type: 'file', class: 'doc-file', style: 'display:none' });
            attach.appendChild(attachSpan);
            attach.appendChild(attachIcon);
            attach.appendChild(fileInput);
            div.appendChild(attach);
            const fileInfo = createSafeElement('div', { class: 'file-info' }, (data && data.fileName) ? data.fileName : 'Файл не выбран');
            div.appendChild(fileInfo);
            attach.addEventListener('click', () => fileInput.click());
            fileInput.addEventListener('change', async (e) => {
                const file = e.target.files[0];
                if (file) {
                    const formData = new FormData();
                    formData.append('file', file);
                    try {
                        const uploadRes = await apiRequest('/files/upload', { method: 'POST', body: formData });
                        fileInfo.textContent = uploadRes.originalName;
                        if (data) data.fileName = uploadRes.originalName;
                    } catch(err) { showToast('Ошибка загрузки файла: ' + err.message, 'warning'); }
                }
            });
            removeIcon.addEventListener('click', async () => {
                this.showConfirmDialog('Удалить документ?', () => {
                    div.remove();
                    if (onRemove) onRemove();
                    showToast('Документ удалён', 'warning');
                });
            });
            return div;
        }

        addOpoBlock(data = null) {
            const template = document.getElementById('opoItemTemplate').content.cloneNode(true);
            const div = template.querySelector('.opo-item');
            if (data) {
                div.querySelector('.opo-name').value = data.name || '';
                div.querySelector('.opo-addr').value = data.address || '';
                div.querySelector('.opo-class').value = data.dangerClass || '';
                div.querySelector('.opo-regnum').value = data.regNumber || '';
                const docsContainer = div.querySelector('.opo-docs-container');
                docsContainer.innerHTML = '';
                if (data.docs) {
                    this.docTypesOpo.forEach(type => {
                        if (data.docs[type.id]) {
                            const block = this.createDocBlock(type, data.docs[type.id], null);
                            docsContainer.appendChild(block);
                        }
                    });
                }
            }
            const addDocBtn = div.querySelector('.add-opo-doc-btn');
            const docTypeSelect = div.querySelector('.opo-doc-type-select');
            docTypeSelect.innerHTML = this.docTypesOpo.map(t => `<option value="${t.id}">${t.title}</option>`).join('');
            addDocBtn.addEventListener('click', () => {
                const typeId = docTypeSelect.value;
                const typeInfo = this.docTypesOpo.find(t => t.id === typeId);
                if (typeInfo) {
                    const block = this.createDocBlock(typeInfo, null, null);
                    div.querySelector('.opo-docs-container').appendChild(block);
                }
            });
            div.querySelector('.remove-opo').addEventListener('click', () => {
                if (this.elements.opoListContainer.children.length <= 1) {
                    showToast('Должен быть хотя бы один ОПО', 'warning');
                    return;
                }
                this.showConfirmDialog('Удалить ОПО?', () => div.remove());
            });
            this.elements.opoListContainer.appendChild(div);
        }

        fillOrgDocs(docs) {
            this.elements.orgDocsContainer.innerHTML = '';
            this.docTypesOrg.forEach(type => {
                if (docs && docs[type.id]) {
                    const block = this.createDocBlock(type, docs[type.id], null);
                    this.elements.orgDocsContainer.appendChild(block);
                }
            });
        }

        fillOpoList(opoList) {
            this.elements.opoListContainer.innerHTML = '';
            if (opoList && opoList.length) opoList.forEach(opo => this.addOpoBlock(opo));
            else this.addOpoBlock();
        }

        renderExpertiseList(org) {
            this.elements.expertiseListContainer.innerHTML = '';
            if (org.expertizy && org.expertizy.length) {
                org.expertizy.forEach((exp, idx) => {
                    const div = createSafeElement('div', { class: 'expertise-item-compact' });
                    const dateFormatted = exp.date ? formatDate(exp.date) : '—';
                    const dateEndFormatted = exp.dateEnd ? formatDate(exp.dateEnd) : '—';
                    const span = createSafeElement('span', {}, `${exp.name} (${exp.type}) — ${exp.expertName || ''}, дата: ${dateFormatted}, окончание: ${dateEndFormatted}`);
                    const actions = createSafeElement('div', { class: 'expertise-actions' });
                    const editIcon = createSafeElement('i', { class: 'fas fa-pen edit-expertise', 'data-idx': idx.toString() });
                    const delIcon = createSafeElement('i', { class: 'fas fa-trash del-expertise', 'data-idx': idx.toString() });
                    actions.appendChild(editIcon); actions.appendChild(delIcon);
                    div.appendChild(span); div.appendChild(actions);
                    this.elements.expertiseListContainer.appendChild(div);
                });
                this.elements.expertiseListContainer.querySelectorAll('.edit-expertise').forEach(btn => btn.addEventListener('click', () => this.openExpertiseModal(org.id, parseInt(btn.dataset.idx))));
                this.elements.expertiseListContainer.querySelectorAll('.del-expertise').forEach(btn => btn.addEventListener('click', () => {
                    this.showConfirmDialog('Удалить экспертизу?', async () => {
                        org.expertizy.splice(parseInt(btn.dataset.idx),1);
                        await apiRequest(`/orgs/${org.id}`, { method: 'PUT', body: JSON.stringify(org) });
                        await this.loadOrganizations();
                        this.renderExpertiseList(org);
                        showToast('Экспертиза удалена', 'warning');
                    });
                }));
            } else this.elements.expertiseListContainer.innerHTML = '<p>Нет экспертиз</p>';
        }

        openOrgModal(org = null) {
            this.elements.modalTitle.innerText = org ? 'Редактирование организации' : 'Новая организация';
            document.querySelectorAll('.error-message').forEach(el => el.classList.remove('visible'));
            document.querySelectorAll('.error').forEach(el => el.classList.remove('error'));
            if (org) {
                this.elements.orgName.value = org.name || '';
                this.elements.orgInn.value = org.inn || '';
                this.elements.orgPhone.value = org.phone || '';
                this.elements.orgEmail.value = org.email || '';
                this.selectedOrgId = org.id;
                this.currentOrgForEdit = JSON.parse(JSON.stringify(org));
                this.fillOrgDocs(org.docs || {});
                this.fillOpoList(org.opoList || []);
                this.renderExpertiseList(org);
            } else {
                this.elements.orgName.value = ''; this.elements.orgInn.value = ''; this.elements.orgPhone.value = ''; this.elements.orgEmail.value = '';
                this.elements.orgDocsContainer.innerHTML = ''; this.elements.opoListContainer.innerHTML = '';
                this.addOpoBlock();
                this.elements.expertiseListContainer.innerHTML = '<p>Нет экспертиз</p>';
                this.selectedOrgId = null;
                this.currentOrgForEdit = null;
            }
            this.elements.orgModal.classList.add('active');
        }

        async saveOrg() {
            if (!this.validateOrgName()) return;
            if (!this.validateOrgInn()) return;
            if (!this.validateOrgPhone()) return;
            if (!this.validateOrgEmail()) return;
            const opoDivs = this.elements.opoListContainer.querySelectorAll('.opo-item');
            let hasValidOpo = false;
            for (let opoDiv of opoDivs) {
                const opoName = opoDiv.querySelector('.opo-name').value.trim();
                if (opoName) { hasValidOpo = true; break; }
            }
            if (!hasValidOpo) {
                showToast('Добавьте хотя бы одно ОПО с названием', 'warning');
                return;
            }
            const orgData = {
                org: this.elements.orgName.value.trim(),
                inn: this.elements.orgInn.value.trim(),
                phone: this.elements.orgPhone.value.trim(),
                email: this.elements.orgEmail.value.trim(),
                opoList: [],
                docs: {},
                expertizy: this.currentOrgForEdit?.expertizy || []
            };
            for (let block of this.elements.orgDocsContainer.querySelectorAll('.org-doc-item')) {
                const docId = block.dataset.docId;
                const fileInfo = block.querySelector('.file-info').textContent;
                const fileName = fileInfo !== 'Файл не выбран' ? fileInfo : '';
                if (this.docTypesOrg.find(t=>t.id===docId)?.hasDuration) {
                    const date = block.querySelector('.doc-date')?.value || '';
                    const duration = block.querySelector('.doc-duration')?.value || '1';
                    const dateEnd = date ? new Date(new Date(date).setFullYear(new Date(date).getFullYear()+parseInt(duration))).toISOString().split('T')[0] : '';
                    orgData.docs[docId] = { date, duration: parseInt(duration), dateEnd, fileName };
                } else orgData.docs[docId] = { fileName };
            }
            for (let opoDiv of this.elements.opoListContainer.querySelectorAll('.opo-item')) {
                const opoName = opoDiv.querySelector('.opo-name').value.trim();
                const opoAddr = opoDiv.querySelector('.opo-addr').value;
                const opoClass = opoDiv.querySelector('.opo-class').value;
                const regNumber = opoDiv.querySelector('.opo-regnum').value;
                const docs = {};
                for (let docBlock of opoDiv.querySelectorAll('.opo-docs-container .org-doc-item')) {
                    const docId = docBlock.dataset.docId;
                    const fileInfo = docBlock.querySelector('.file-info').textContent;
                    const fileName = fileInfo !== 'Файл не выбран' ? fileInfo : '';
                    if (this.docTypesOpo.find(t=>t.id===docId)?.hasDuration) {
                        const date = docBlock.querySelector('.doc-date')?.value || '';
                        const duration = docBlock.querySelector('.doc-duration')?.value || '1';
                        const dateEnd = date ? new Date(new Date(date).setFullYear(new Date(date).getFullYear()+parseInt(duration))).toISOString().split('T')[0] : '';
                        docs[docId] = { date, duration: parseInt(duration), dateEnd, fileName };
                    } else docs[docId] = { fileName };
                }
                orgData.opoList.push({ opoName, opoAddr, opoClass, regNumber, docs });
            }
            this.setButtonLoading(this.elements.saveOrgBtn, true, 'Сохранить');
            try {
                if (this.selectedOrgId) {
                    await apiRequest(`/orgs/${this.selectedOrgId}`, { method: 'PUT', body: JSON.stringify(orgData) });
                    showToast('Организация обновлена', 'success');
                } else {
                    await apiRequest('/orgs', { method: 'POST', body: JSON.stringify(orgData) });
                    showToast('Организация добавлена', 'success');
                }
                await this.loadOrganizations();
                this.elements.orgModal.classList.remove('active');
            } catch (err) {
                showToast(err.message, 'warning');
            } finally {
                this.setButtonLoading(this.elements.saveOrgBtn, false);
            }
        }

        async deleteOrg() {
            if (!this.selectedOrgId) return;
            this.setButtonLoading(this.elements.deleteOrgBtn, true, 'Удалить');
            try {
                await apiRequest(`/orgs/${this.selectedOrgId}`, { method: 'DELETE' });
                await this.loadOrganizations();
                this.elements.orgModal.classList.remove('active');
                showToast('Организация удалена', 'success');
            } catch (err) {
                showToast(err.message, 'warning');
            } finally {
                this.setButtonLoading(this.elements.deleteOrgBtn, false);
            }
        }

        openExpertiseModal(orgId, index = -1) {
            const org = this.organizations.find(o => o.id === orgId);
            if (!org) return;
            this.elements.expertiseOrgName.value = org.name;
            this.elements.expertiseName.value = '';
            this.elements.expertiseType.value = 'ЗС';
            this.elements.expertiseDate.value = '';
            this.elements.expertiseDuration.value = '1';
            this.elements.expertiseExpert.value = '';
            this.elements.expertiseFileInfo.textContent = 'Файл не выбран';
            this.elements.expertiseFile.value = '';
            if (index >= 0 && org.expertizy && org.expertizy[index]) {
                const exp = org.expertizy[index];
                this.elements.expertiseName.value = exp.name;
                this.elements.expertiseType.value = exp.type;
                this.elements.expertiseDate.value = exp.date || '';
                this.elements.expertiseDuration.value = exp.duration || '1';
                this.elements.expertiseExpert.value = exp.expertName || '';
                if (exp.fileName) this.elements.expertiseFileInfo.textContent = exp.fileName;
                this.elements.expertiseModal.dataset.editIndex = index;
                this.elements.expertiseModalTitle.innerText = 'Редактирование экспертизы';
            } else {
                this.elements.expertiseModal.dataset.editIndex = '-1';
                this.elements.expertiseModalTitle.innerText = 'Новая экспертиза';
            }
            this.elements.expertiseModal.dataset.orgId = orgId;
            this.elements.expertiseModal.classList.add('active');
        }

        async saveExpertise() {
            const orgId = parseInt(this.elements.expertiseModal.dataset.orgId);
            const editIndex = parseInt(this.elements.expertiseModal.dataset.editIndex);
            const name = this.elements.expertiseName.value.trim();
            if (!name) { showToast('Введите название экспертизы', 'warning'); return; }
            const type = this.elements.expertiseType.value;
            const date = this.elements.expertiseDate.value;
            const duration = parseInt(this.elements.expertiseDuration.value);
            const expert = this.elements.expertiseExpert.value.trim();
            const fileName = this.elements.expertiseFileInfo.textContent !== 'Файл не выбран' ? this.elements.expertiseFileInfo.textContent : '';
            const dateEnd = date ? new Date(new Date(date).setFullYear(new Date(date).getFullYear()+duration)).toISOString().split('T')[0] : '';
            const expData = { name, type, date, duration, dateEnd, expertName: expert, fileName };
            const org = this.organizations.find(o => o.id === orgId);
            if (!org) return;
            if (editIndex >= 0 && org.expertizy && org.expertizy[editIndex]) {
                org.expertizy[editIndex] = expData;
            } else {
                if (!org.expertizy) org.expertizy = [];
                org.expertizy.push(expData);
            }
            this.setButtonLoading(this.elements.saveExpertise, true, 'Сохранить');
            try {
                await apiRequest(`/orgs/${orgId}`, { method: 'PUT', body: JSON.stringify(org) });
                await this.loadOrganizations();
                this.elements.expertiseModal.classList.remove('active');
                showToast('Экспертиза сохранена', 'success');
            } catch (err) {
                showToast(err.message, 'warning');
            } finally {
                this.setButtonLoading(this.elements.saveExpertise, false);
            }
        }

        async generateReport(period) {
            let daysFilter = null;
            if (period === 'month') daysFilter = 30;
            if (period === 'twoMonths') daysFilter = 60;
            const allDocs = [];
            for (let org of this.organizations) {
                const docs = [];
                if (org.docs) Object.entries(org.docs).forEach(([type, doc]) => {
                    if (doc.dateEnd) {
                        const isExpiredDoc = isExpired(doc.dateEnd);
                        const isExpiring = daysFilter !== null && !isExpiredDoc && (new Date(doc.dateEnd.split('T')[0]) - new Date()) <= daysFilter*86400000;
                        if ((period === 'expired' && isExpiredDoc) || (daysFilter !== null && isExpiring)) {
                            const title = this.docTypesOrg.find(t=>t.id===type)?.title || type;
                            docs.push({ type: 'Документ организации', name: title, dateEnd: doc.dateEnd });
                        }
                    }
                });
                if (org.expertizy) org.expertizy.forEach(exp => {
                    if (exp.dateEnd) {
                        const isExpiredExp = isExpired(exp.dateEnd);
                        const isExpiring = daysFilter !== null && !isExpiredExp && (new Date(exp.dateEnd.split('T')[0]) - new Date()) <= daysFilter*86400000;
                        if ((period === 'expired' && isExpiredExp) || (daysFilter !== null && isExpiring)) {
                            docs.push({ type: 'Экспертиза', name: `${exp.name} (${exp.type})`, dateEnd: exp.dateEnd });
                        }
                    }
                });
                if (org.opoList) org.opoList.forEach(opo => {
                    if (opo.docs) Object.entries(opo.docs).forEach(([type, doc]) => {
                        if (doc.dateEnd) {
                            const isExpiredDoc = isExpired(doc.dateEnd);
                            const isExpiring = daysFilter !== null && !isExpiredDoc && (new Date(doc.dateEnd.split('T')[0]) - new Date()) <= daysFilter*86400000;
                            if ((period === 'expired' && isExpiredDoc) || (daysFilter !== null && isExpiring)) {
                                const title = this.docTypesOpo.find(t=>t.id===type)?.title || type;
                                docs.push({ type: `Документ ОПО (${opo.name})`, name: title, dateEnd: doc.dateEnd });
                            }
                        }
                    });
                });
                docs.forEach(d => allDocs.push({ Организация: org.name, Тип: d.type, Название: d.name, 'Дата окончания': formatDate(d.dateEnd) }));
            }
            if (allDocs.length === 0) { showToast('Нет документов, соответствующих выбранному периоду', 'info'); return; }
            this.showReportResult(period === 'expired' ? 'Просроченные документы' : (period === 'month' ? 'Истекают через месяц' : 'Истекают через два месяца'), allDocs);
        }

        async generateMissingDocsReport() {
            this.setButtonLoading(this.elements.reportMissingDocsBtn, true, 'Загрузка');
            try {
                const data = await apiRequest('/orgs/reports/missing-docs', { method: 'GET' });
                if (!data.length) { showToast('Все организации имеют необходимые документы', 'info'); return; }
                const mappedData = data.map(item => ({
                    'Организация': item.org_name,
                    'ОПО': item.opo_name || '—',
                    'Отсутствующий документ': item.doc_type,
                    'Причина': item.reason
                }));
                this.showReportResult('Организации без подгруженных документов', mappedData);
            } catch (err) {
                showToast('Ошибка: ' + err.message, 'warning');
            } finally {
                this.setButtonLoading(this.elements.reportMissingDocsBtn, false);
            }
        }

        async generateIncompleteReport() {
            this.setButtonLoading(this.elements.reportIncompleteBtn, true, 'Загрузка');
            try {
                const data = await apiRequest('/orgs/reports/incomplete-cards', { method: 'GET' });
                if (!data.length) { showToast('Нет незаполненных обязательных полей', 'info'); return; }
                const mappedData = data.map(item => ({
                    'Организация': item.org_name,
                    'Секция': item.section,
                    'Поле': item.field,
                    'Текущее значение': item.value || '—'
                }));
                this.showReportResult('Незаполненные поля', mappedData);
            } catch (err) {
                showToast('Ошибка: ' + err.message, 'warning');
            } finally {
                this.setButtonLoading(this.elements.reportIncompleteBtn, false);
            }
        }

        showReportResult(title, data) {
            this.elements.reportResultTitle.innerText = title;
            this.currentReportData = data;
            const container = this.elements.reportResultContent;
            container.innerHTML = '';
            if (!data.length) {
                container.innerHTML = '<p>Нет данных для отображения</p>';
                this.elements.reportResultModal.classList.add('active');
                return;
            }
            const headers = Object.keys(data[0]);
            const table = createSafeElement('table', { class: 'report-table' });
            const thead = createSafeElement('thead');
            const headerRow = createSafeElement('tr');
            headers.forEach(h => {
                const th = createSafeElement('th', {}, h);
                headerRow.appendChild(th);
            });
            thead.appendChild(headerRow);
            table.appendChild(thead);
            const tbody = createSafeElement('tbody');
            data.forEach(row => {
                const tr = createSafeElement('tr');
                headers.forEach(h => {
                    const td = createSafeElement('td', {}, row[h] !== undefined ? String(row[h]) : '—');
                    tr.appendChild(td);
                });
                tbody.appendChild(tr);
            });
            table.appendChild(tbody);
            container.appendChild(table);
            this.elements.reportResultModal.classList.add('active');
        }

        exportReportToExcel() {
            if (!this.currentReportData || !this.currentReportData.length) {
                showToast('Нет данных для экспорта', 'warning');
                return;
            }
            const ws = XLSX.utils.json_to_sheet(this.currentReportData);
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, 'Отчёт');
            XLSX.writeFile(wb, `report_${new Date().toISOString().slice(0,19)}.xlsx`);
            showToast('Экспорт выполнен', 'success');
        }

        exportExcel() {
            this.setButtonLoading(this.elements.exportBtn, true, 'Экспорт');
            try {
                const data = this.filteredOrgs.map((org, idx) => ({
                    '№': idx+1,
                    'Дата добавления': org.createdAt,
                    'Организация': org.name,
                    'ИНН': org.inn,
                    'Телефон': org.phone,
                    'Email': org.email,
                    'ОПО': (org.opoList||[]).map(o=>o.name).join(', '),
                    'Кол-во ОПО': (org.opoList||[]).length,
                    'Кол-во ЭПБ': (org.expertizy||[]).length,
                    'Просроченных документов': this.countExpired(org)
                }));
                const ws = XLSX.utils.json_to_sheet(data);
                const wb = XLSX.utils.book_new();
                XLSX.utils.book_append_sheet(wb, ws, 'Организации');
                XLSX.writeFile(wb, `archive_${new Date().toISOString().slice(0,19)}.xlsx`);
                showToast('Экспорт выполнен', 'success');
            } catch (err) {
                showToast('Ошибка экспорта: ' + err.message, 'warning');
            } finally {
                this.setButtonLoading(this.elements.exportBtn, false);
            }
        }

        async importExcel(e) {
            const file = e.target.files[0];
            if (!file) return;
            const formData = new FormData();
            formData.append('file', file);
            this.setButtonLoading(this.elements.importBtn, true, 'Импорт');
            try {
                const response = await apiRequest('/orgs/import-excel', { method: 'POST', body: formData });
                showToast(`Импорт завершён. Добавлено организаций: ${response.stats.addedOrganizations}, экспертиз: ${response.stats.addedExpertises}, пропущено: ${response.stats.skipped}`, 'success');
                if (response.stats.errors && response.stats.errors.length) {
                    console.warn('Ошибки импорта:', response.stats.errors);
                    showToast(`Были ошибки: ${response.stats.errors.slice(0,3).join('; ')}`, 'warning');
                }
                await this.loadOrganizations();
            } catch (err) {
                showToast('Ошибка при импорте: ' + err.message, 'warning');
            } finally {
                this.setButtonLoading(this.elements.importBtn, false);
                e.target.value = '';
            }
        }

        async exportDatabaseBackup() {
            this.setButtonLoading(this.elements.backupBtn, true, 'Экспорт');
            try {
                const response = await fetch(`${API_URL}/orgs/export-db`, {
                    method: 'GET',
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                if (!response.ok) throw new Error('Ошибка создания дампа');
                const blob = await response.blob();
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = `backup_${new Date().toISOString().slice(0,19)}.sql`;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                URL.revokeObjectURL(url);
                showToast('Дамп базы данных скачан', 'success');
            } catch (err) {
                showToast('Ошибка: ' + err.message, 'warning');
            } finally {
                this.setButtonLoading(this.elements.backupBtn, false);
            }
        }
    }

    window.app = new App();
})();
</script>
</body>
</html>
