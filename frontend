        setButtonLoading(button, isLoading, originalText = null) {
            if (isLoading) {
                button.dataset.originalText = button.textContent;
                button.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Загрузка...';
                button.disabled = true;
            } else {
                button.textContent = button.dataset.originalText || (originalText || button.textContent);
                button.disabled = false;
            }
        }

        init() {
            this.bindAuthEvents();
            this.bindMainEvents();
            this.updateAuthMode();
            this.setupLiveValidation();
            this.setupDropdown();
            if (token) {
                const savedUsername = localStorage.getItem('username');
                if (savedUsername) this.elements.currentUsername.innerText = savedUsername;
                this.elements.authModal.classList.remove('active');
                this.elements.mainUI.style.display = 'block';
                this.loadOrganizations();
            } else {
                this.elements.authModal.classList.add('active');
                this.elements.mainUI.style.display = 'none';
            }
        }

        setupDropdown() {
            this.elements.reportDropdownBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                const isVisible = this.elements.reportDropdownMenu.style.display === 'block';
                this.elements.reportDropdownMenu.style.display = isVisible ? 'none' : 'block';
            });
            document.addEventListener('click', () => {
                this.elements.reportDropdownMenu.style.display = 'none';
            });
            this.elements.reportExpiredBtn.addEventListener('click', () => this.generateReport('expired'));
            this.elements.reportMonthBtn.addEventListener('click', () => this.generateReport('month'));
            this.elements.reportTwoMonthsBtn.addEventListener('click', () => this.generateReport('twoMonths'));
            this.elements.reportMissingDocsBtn.addEventListener('click', () => this.generateMissingDocsReport());
            this.elements.reportIncompleteBtn.addEventListener('click', () => this.generateIncompleteReport());
        }

        setupLiveValidation() {
            this.elements.orgName.addEventListener('blur', () => this.validateOrgName());
            this.elements.orgInn.addEventListener('input', () => this.validateOrgInn());
            this.elements.orgPhone.addEventListener('input', () => this.validateOrgPhone());
            this.elements.orgEmail.addEventListener('blur', () => this.validateOrgEmail());
        }

        validateOrgName() {
            const value = this.elements.orgName.value.trim();
            if (!value) {
                this.elements.orgNameError.innerText = 'Название обязательно';
                this.elements.orgNameError.classList.add('visible');
                this.elements.orgName.classList.add('error');
                return false;
            } else {
                this.elements.orgNameError.classList.remove('visible');
                this.elements.orgName.classList.remove('error');
                return true;
            }
        }

        validateOrgInn() {
            const value = this.elements.orgInn.value;
            const digitsOnly = value.replace(/\D/g, '');
            const isValid = digitsOnly.length >= 10 && digitsOnly.length <= 12;
            if (value && !isValid) {
                this.elements.orgInnError.innerText = 'ИНН должен содержать 10-12 цифр';
                this.elements.orgInnError.classList.add('visible');
                this.elements.orgInn.classList.add('error');
                return false;
            } else {
                this.elements.orgInnError.classList.remove('visible');
                this.elements.orgInn.classList.remove('error');
                return true;
            }
        }

        validateOrgPhone() {
            const value = this.elements.orgPhone.value;
            const digitsOnly = value.replace(/\D/g, '');
            const isValid = digitsOnly.length >= 10 && digitsOnly.length <= 12;
            if (value && !isValid) {
                this.elements.orgPhoneError.innerText = 'Неверный формат телефона (10-12 цифр)';
                this.elements.orgPhoneError.classList.add('visible');
                this.elements.orgPhone.classList.add('error');
                return false;
            } else {
                this.elements.orgPhoneError.classList.remove('visible');
                this.elements.orgPhone.classList.remove('error');
                return true;
            }
        }

        validateOrgEmail() {
            const value = this.elements.orgEmail.value.trim();
            if (value && !/^[^\s@]+@([^\s@]+\.)+[^\s@]+$/.test(value)) {
                this.elements.orgEmailError.innerText = 'Неверный email';
                this.elements.orgEmailError.classList.add('visible');
                this.elements.orgEmail.classList.add('error');
                return false;
            } else {
                this.elements.orgEmailError.classList.remove('visible');
                this.elements.orgEmail.classList.remove('error');
                return true;
            }
        }

        bindAuthEvents() {
            this.elements.switchAuthBtn.addEventListener('click', () => {
                this.isLoginMode = !this.isLoginMode;
                this.updateAuthMode();
            });
            this.elements.submitAuthBtn.addEventListener('click', async () => {
                const username = this.elements.authUsername.value.trim();
                const password = this.elements.authPassword.value;
                const email = this.elements.authEmail.value.trim();
                if (!username || !password) {
                    this.elements.authError.innerText = 'Заполните имя пользователя и пароль';
                    this.elements.authError.style.display = 'block';
                    return;
                }
                if (!this.isLoginMode && (!email.includes('@') || email.length < 5)) {
                    this.elements.authError.innerText = 'Введите корректный email';
                    this.elements.authError.style.display = 'block';
                    return;
                }
                this.setButtonLoading(this.elements.submitAuthBtn, true, this.isLoginMode ? 'Войти' : 'Зарегистрироваться');
                try {
                    let response;
                    if (this.isLoginMode) {
                        response = await fetch(`${API_URL}/auth/login`, {
                            method: 'POST', headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ username, password })
                        });
                    } else {
                        response = await fetch(`${API_URL}/auth/register`, {
                            method: 'POST', headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ username, email, password })
                        });
                    }
                    const data = await response.json();
                    if (!response.ok) throw new Error(data.message);
                    token = data.token;
                    localStorage.setItem('token', token);
                    currentUser = data.user;
                    localStorage.setItem('username', currentUser.username);
                    this.elements.currentUsername.innerText = currentUser.username;
                    this.elements.authModal.classList.remove('active');
                    this.elements.mainUI.style.display = 'block';
                    await this.loadOrganizations();
                    showToast(`Добро пожаловать, ${username}!`, 'success');
                } catch (err) {
                    this.elements.authError.innerText = err.message;
                    this.elements.authError.style.display = 'block';
                } finally {
                    this.setButtonLoading(this.elements.submitAuthBtn, false);
                }
            });
            this.elements.logoutBtn.addEventListener('click', () => {
                localStorage.removeItem('token');
                localStorage.removeItem('username');
                token = null;
                this.elements.mainUI.style.display = 'none';
                this.elements.authModal.classList.add('active');
                this.isLoginMode = true;
                this.updateAuthMode();
                this.elements.currentUsername.innerText = '';
            });
            this.elements.closeAuthModal.addEventListener('click', () => this.elements.authModal.classList.remove('active'));
        }

        updateAuthMode() {
            if (this.isLoginMode) {
                this.elements.authModalTitle.innerText = 'Вход';
                this.elements.switchAuthBtn.innerText = 'Регистрация';
                this.elements.submitAuthBtn.innerText = 'Войти';
                this.elements.authEmailRow.style.display = 'none';
            } else {
                this.elements.authModalTitle.innerText = 'Регистрация';
                this.elements.switchAuthBtn.innerText = 'Вход';
                this.elements.submitAuthBtn.innerText = 'Зарегистрироваться';
                this.elements.authEmailRow.style.display = 'block';
            }
            this.elements.authError.style.display = 'none';
        }

        async loadOrganizations() {
            try {
                const data = await apiRequest('/orgs', { method: 'GET' });
                this.organizations = data;
                this.applyFilterAndSort();
                this.initVirtualScroll();
            } catch (err) { showToast(err.message, 'warning'); }
        }

        countExpired(org) {
            let c = 0;
            if (org.docs) Object.values(org.docs).forEach(d => { if (d.dateEnd && isExpired(d.dateEnd)) c++; });
            if (org.opoList) org.opoList.forEach(opo => { if (opo.docs) Object.values(opo.docs).forEach(d => { if (d.dateEnd && isExpired(d.dateEnd)) c++; }); });
            if (org.expertizy) org.expertizy.forEach(e => { if (e.dateEnd && isExpired(e.dateEnd)) c++; });
            return c;
        }

        getExpiredDocsList(org) {
            const items = [];
            if (org.docs) Object.entries(org.docs).forEach(([type, doc]) => {
                if (doc.dateEnd && isExpired(doc.dateEnd)) {
                    const title = this.docTypesOrg.find(t => t.id === type)?.title || type;
                    items.push(`📄 ${title} (до ${formatDate(doc.dateEnd)})`);
                }
            });
            if (org.expertizy) org.expertizy.forEach(exp => {
                if (exp.dateEnd && isExpired(exp.dateEnd)) {
                    items.push(`🔬 Экспертиза: ${exp.name} (${exp.type}, до ${formatDate(exp.dateEnd)})`);
                }
            });
            if (org.opoList) org.opoList.forEach(opo => {
                if (opo.docs) Object.entries(opo.docs).forEach(([type, doc]) => {
                    if (doc.dateEnd && isExpired(doc.dateEnd)) {
                        const title = this.docTypesOpo.find(t => t.id === type)?.title || type;
                        items.push(`🏭 ОПО "${opo.name}": ${title} (до ${formatDate(doc.dateEnd)})`);
                    }
                });
            });
            return items.length ? items.join('; ') : '—';
        }

        applyFilterAndSort() {
            let filtered = this.organizations.filter(org => {
                if (!this.searchTerm) return true;
                const s = this.searchTerm.toLowerCase();
                return org.name?.toLowerCase().includes(s) || (org.opoList || []).some(o => o.name?.toLowerCase().includes(s)) || org.inn?.includes(s);
            });
            filtered.sort((a,b) => {
                let av,bv;
                if (this.sortField === 'npp') return this.sortDir === 'asc' ? a.id - b.id : b.id - a.id;
                if (this.sortField === 'createdAt') { av = a.createdAt||''; bv = b.createdAt||''; }
                else if (this.sortField === 'org') { av = a.name||''; bv = b.name||''; }
                else if (this.sortField === 'opoNames') { av = (a.opoList||[]).map(o=>o.name).join(','); bv = (b.opoList||[]).map(o=>o.name).join(','); }
                else if (this.sortField === 'opoCount') { av = (a.opoList||[]).length; bv = (b.opoList||[]).length; }
                else if (this.sortField === 'expertiseCount') { av = (a.expertizy||[]).length; bv = (b.expertizy||[]).length; }
                else if (this.sortField === 'expiredCount') { av = this.countExpired(a); bv = this.countExpired(b); }
                else return 0;
                if (this.sortDir === 'asc') return av > bv ? 1 : -1;
                else return av < bv ? 1 : -1;
            });
            this.filteredOrgs = filtered;
            this.currentPage = 1;
            this.renderVirtual();
        }

        initVirtualScroll() {
            const calculateVisibleRows = () => {
                if (this.wrapper) {
                    const containerHeight = this.wrapper.clientHeight;
                    this.visibleRows = Math.ceil(containerHeight / this.rowHeight) + 3;
                }
            };
            calculateVisibleRows();
            window.addEventListener('resize', () => { calculateVisibleRows(); this.renderVirtual(); });
            if (this.scrollHandler) this.wrapper.removeEventListener('scroll', this.scrollHandler);
            this.scrollHandler = () => {
                if (!this.wrapper) return;
                const scrollTop = this.wrapper.scrollTop;
                const newStartIndex = Math.floor(scrollTop / this.rowHeight);
                if (newStartIndex !== this.startIndex) {
                    this.startIndex = newStartIndex;
                    this.renderVirtual();
                }
            };
            this.wrapper.addEventListener('scroll', this.scrollHandler);
            this.renderVirtual();
        }

        createRowElement(org, npp) {
            const row = createSafeElement('tr', { 'data-id': org.id.toString() });
            if (this.countExpired(org) > 0) row.classList.add('expired-row');
            const cells = [
                npp.toString(),
                org.createdAt ? formatDate(org.createdAt) : '—',
                org.name || '',
                (org.opoList || []).map(o => o.name).join(', '),
                (org.opoList || []).length.toString(),
                (org.expertizy || []).length.toString(),
                this.countExpired(org).toString(),
                this.getExpiredDocsList(org)
            ];
            cells.forEach((cellText, i) => {
                const td = createSafeElement('td', { title: cellText }, cellText);
                if (i === 7) td.classList.add('expired-docs-cell');
                row.appendChild(td);
            });
            return row;
        }

        renderVirtual() {
            if (!this.tbody) return;
            const startIdxGlobal = (this.currentPage-1) * this.itemsPerPage;
            const endIdxGlobal = Math.min(startIdxGlobal + this.itemsPerPage, this.filteredOrgs.length);
            const totalRows = endIdxGlobal - startIdxGlobal;
            if (totalRows === 0) {
                this.tbody.innerHTML = '<tr><td colspan="8" style="text-align:center">Нет данных</td></tr>';
                return;
            }
            const startRender = Math.max(0, this.startIndex);
            const endRender = Math.min(totalRows, this.startIndex + this.visibleRows);
            const fragment = document.createDocumentFragment();
            const spacerTop = document.createElement('tr');
            spacerTop.style.height = `${startRender * this.rowHeight}px`;
            spacerTop.style.background = 'transparent';
            fragment.appendChild(spacerTop);
            for (let i = startRender; i < endRender; i++) {
                const globalIndex = startIdxGlobal + i;
                if (globalIndex >= this.filteredOrgs.length) break;
                const org = this.filteredOrgs[globalIndex];
                const row = this.createRowElement(org, globalIndex+1);
                fragment.appendChild(row);
            }
            const spacerBottom = document.createElement('tr');
            const bottomHeight = Math.max(0, (totalRows - endRender) * this.rowHeight);
            spacerBottom.style.height = `${bottomHeight}px`;
            spacerBottom.style.background = 'transparent';
            fragment.appendChild(spacerBottom);
            this.tbody.innerHTML = '';
            this.tbody.appendChild(fragment);
            if (this.selectedOrgId) this.setSelectedId(this.selectedOrgId);
        }

        setSelectedId(id) {
            document.querySelectorAll('#tableBody tr').forEach(row => {
                if (parseInt(row.dataset.id) === id) row.classList.add('selected');
                else row.classList.remove('selected');
            });
        }

        bindMainEvents() {
            this.elements.searchInput.addEventListener('input', (e) => { this.searchTerm = e.target.value; this.applyFilterAndSort(); });
            document.querySelectorAll('th[data-sort]').forEach(th => {
                th.addEventListener('click', () => {
                    const field = th.dataset.sort;
                    if (this.sortField === field) this.sortDir = this.sortDir === 'asc' ? 'desc' : 'asc';
                    else { this.sortField = field; this.sortDir = 'asc'; }
                    this.applyFilterAndSort();
                });
            });
            this.elements.itemsPerPage.addEventListener('change', (e) => { this.itemsPerPage = parseInt(e.target.value); this.currentPage = 1; this.applyFilterAndSort(); });
            this.elements.prevPage.addEventListener('click', () => { if (this.currentPage > 1) { this.currentPage--; this.applyFilterAndSort(); } });
            this.elements.nextPage.addEventListener('click', () => { const totalPages = Math.ceil(this.filteredOrgs.length/this.itemsPerPage); if (this.currentPage < totalPages) { this.currentPage++; this.applyFilterAndSort(); } });
            this.elements.tbody.addEventListener('click', (e) => {
                const row = e.target.closest('tr');
                if (row && row.dataset.id) {
                    this.selectedOrgId = parseInt(row.dataset.id);
                    this.setSelectedId(this.selectedOrgId);
                }
            });
            this.elements.tbody.addEventListener('dblclick', (e) => {
                const row = e.target.closest('tr');
                if (row && row.dataset.id) {
                    const id = parseInt(row.dataset.id);
                    const org = this.organizations.find(o => o.id === id);
                    if (org) this.openOrgModal(org);
                }
            });
            this.elements.addOrgBtn.addEventListener('click', () => this.openOrgModal());
            this.elements.cancelModal.addEventListener('click', () => this.elements.orgModal.classList.remove('active'));
            this.elements.closeOrgModal.addEventListener('click', () => this.elements.orgModal.classList.remove('active'));
            this.elements.collapseCardBtn.addEventListener('click', () => this.elements.orgModal.classList.remove('active'));
            this.elements.saveOrgBtn.addEventListener('click', () => this.saveOrg());
            this.elements.deleteOrgBtn.addEventListener('click', () => this.showConfirmDialog('Удалить организацию?', () => this.deleteOrg()));
            this.elements.addOpoBtn.addEventListener('click', () => this.addOpoBlock());
            this.elements.addExpertiseInOrgBtn.addEventListener('click', () => { if (this.selectedOrgId) this.openExpertiseModal(this.selectedOrgId, -1); else showToast('Сначала выберите организацию', 'warning'); });
            this.elements.exportBtn.addEventListener('click', () => this.exportExcel());
            this.elements.importBtn.addEventListener('click', () => this.elements.importFileInput.click());
            this.elements.importFileInput.addEventListener('change', async (e) => await this.importExcel(e));
            this.elements.backupBtn.addEventListener('click', () => this.exportDatabaseBackup());
            this.elements.cancelExpertiseModal.addEventListener('click', () => this.elements.expertiseModal.classList.remove('active'));
            this.elements.closeExpertiseModal.addEventListener('click', () => this.elements.expertiseModal.classList.remove('active'));
            this.elements.saveExpertise.addEventListener('click', () => this.saveExpertise());
            this.elements.expertiseFileAttach.addEventListener('click', () => this.elements.expertiseFile.click());
            this.elements.expertiseFile.addEventListener('change', async (e) => {
                const file = e.target.files[0];
                if (file) {
                    const formData = new FormData();
                    formData.append('file', file);
                    try {
                        const res = await apiRequest('/files/upload', { method: 'POST', body: formData });
                        this.elements.expertiseFileInfo.textContent = res.originalName;
                    } catch(err) { showToast('Ошибка загрузки файла', 'warning'); }
                }
            });
            this.elements.orgDocTypeSelect.innerHTML = this.docTypesOrg.map(t => `<option value="${t.id}">${t.title}</option>`).join('');
            this.elements.addOrgDocBtn.addEventListener('click', () => {
                const typeId = this.elements.orgDocTypeSelect.value;
                const typeInfo = this.docTypesOrg.find(t => t.id === typeId);
                if (typeInfo) {
                    const block = this.createDocBlock(typeInfo, null, null);
                    this.elements.orgDocsContainer.appendChild(block);
                }
