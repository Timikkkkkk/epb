const { pool } = require('../config/database');

// 1. Отчёт "Организации без подгруженных документов"
exports.getMissingDocsReport = async (req, res) => {
    const { docType } = req.query; // опциональный фильтр по типу документа
    try {
        // Получаем все организации пользователя (или все, если общая база)
        const orgsResult = await pool.query('SELECT id, name FROM organizations ORDER BY id');
        const report = [];

        for (const org of orgsResult.rows) {
            // Для каждого типа документа (из docTypesOrg) проверяем наличие документа
            const docTypes = [
                { id: 'prod', title: 'Производственный контроль' },
                { id: 'plan', title: 'План мероприятий' },
                { id: 'dogovor', title: 'Договор с АСС' },
                { id: 'finance', title: 'Фин. средства' },
                { id: 'protocol', title: 'Протокол аттестации' },
                { id: 'svidetelstvo', title: 'Свидетельство ОПО' },
                { id: 'other', title: 'Прочие' }
            ];
            // Если указан конкретный тип, фильтруем
            const typesToCheck = docType ? docTypes.filter(t => t.id === docType) : docTypes;
            
            for (const type of typesToCheck) {
                // Проверяем наличие документа организации
                const docResult = await pool.query(
                    'SELECT id, file_name, date, date_end FROM org_documents WHERE organization_id = $1 AND doc_type = $2',
                    [org.id, type.id]
                );
                const doc = docResult.rows[0];
                let reason = null;
                if (!doc) {
                    reason = 'Документ отсутствует';
                } else if (!doc.file_name || doc.file_name === '') {
                    reason = 'Файл не загружен';
                } else if (!doc.date || !doc.date_end) {
                    reason = 'Не заполнены даты (начала или окончания)';
                }
                if (reason) {
                    report.push({
                        org_name: org.name,
                        opo_name: null,
                        doc_type: type.title,
                        reason: reason
                    });
                }
            }

            // Проверяем документы ОПО
            const opoResult = await pool.query('SELECT id, name FROM opo_objects WHERE organization_id = $1', [org.id]);
            for (const opo of opoResult.rows) {
                const opoDocTypes = [
                    { id: 'ins', title: 'Страховой полис' },
                    { id: 'char', title: 'Сведения характеризующие' },
                    { id: 'expertTU', title: 'Экспертиза ТУ' },
                    { id: 'expertZS', title: 'Экспертиза ЗС' }
                ];
                const typesToCheckOpo = docType ? opoDocTypes.filter(t => t.id === docType) : opoDocTypes;
                for (const type of typesToCheckOpo) {
                    const docResult = await pool.query(
                        'SELECT id, file_name, date, date_end FROM opo_documents WHERE opo_id = $1 AND doc_type = $2',
                        [opo.id, type.id]
                    );
                    const doc = docResult.rows[0];
                    let reason = null;
                    if (!doc) {
                        reason = 'Документ отсутствует';
                    } else if (!doc.file_name || doc.file_name === '') {
                        reason = 'Файл не загружен';
                    } else if (!doc.date || !doc.date_end) {
                        reason = 'Не заполнены даты (начала или окончания)';
                    }
                    if (reason) {
                        report.push({
                            org_name: org.name,
                            opo_name: opo.name,
                            doc_type: type.title,
                            reason: reason
                        });
                    }
                }
            }
        }

        res.json(report);
    } catch (error) {
        console.error(error);
        res.status(500).json({ message: 'Ошибка при формировании отчёта' });
    }
};

// 2. Отчёт "Организации с незаполненными полями" (проверка обязательных полей)
exports.getIncompleteCardsReport = async (req, res) => {
    try {
        const orgsResult = await pool.query('SELECT id, name, inn, phone, email FROM organizations ORDER BY id');
        const report = [];

        for (const org of orgsResult.rows) {
            // Проверка полей организации (обязательные: name)
            if (!org.name || org.name.trim() === '') {
                report.push({
                    org_name: org.name || '(без названия)',
                    section: 'Организация',
                    field: 'Название',
                    value: org.name || ''
                });
            }
            // ИНН, телефон, email – не обязательны, но можно проверить на пустоту
            if (!org.inn || org.inn.trim() === '') {
                report.push({
                    org_name: org.name,
                    section: 'Организация',
                    field: 'ИНН',
                    value: ''
                });
            }
            // Проверка ОПО
            const opoResult = await pool.query('SELECT id, name, danger_class, reg_number FROM opo_objects WHERE organization_id = $1', [org.id]);
            for (const opo of opoResult.rows) {
                if (!opo.name || opo.name.trim() === '') {
                    report.push({
                        org_name: org.name,
                        section: `ОПО (id:${opo.id})`,
                        field: 'Название',
                        value: opo.name || ''
                    });
                }
                if (!opo.danger_class || opo.danger_class.trim() === '') {
                    report.push({
                        org_name: org.name,
                        section: `ОПО "${opo.name || 'без названия'}"`,
                        field: 'Класс опасности',
                        value: opo.danger_class || ''
                    });
                }
                // reg_number не обязателен, но можно отметить пустоту
                if (!opo.reg_number || opo.reg_number.trim() === '') {
                    report.push({
                        org_name: org.name,
                        section: `ОПО "${opo.name || 'без названия'}"`,
                        field: 'Регистрационный номер',
                        value: ''
                    });
                }
            }
            // Проверка экспертиз
            const expertisesResult = await pool.query('SELECT id, name, date, date_end, expert_name FROM expertises WHERE organization_id = $1', [org.id]);
            for (const exp of expertisesResult.rows) {
                if (!exp.name || exp.name.trim() === '') {
                    report.push({
                        org_name: org.name,
                        section: 'Экспертиза',
                        field: 'Название',
                        value: exp.name || ''
                    });
                }
                if (!exp.date) {
                    report.push({
                        org_name: org.name,
                        section: `Экспертиза "${exp.name || 'без названия'}"`,
                        field: 'Дата проведения',
                        value: ''
                    });
                }
                if (!exp.date_end) {
                    report.push({
                        org_name: org.name,
                        section: `Экспертиза "${exp.name || 'без названия'}"`,
                        field: 'Дата окончания',
                        value: ''
                    });
                }
                // expert_name не обязателен, но можно проверить
                if (!exp.expert_name || exp.expert_name.trim() === '') {
                    report.push({
                        org_name: org.name,
                        section: `Экспертиза "${exp.name || 'без названия'}"`,
                        field: 'Ф.И.О. эксперта',
                        value: ''
                    });
                }
            }
            // Проверка документов организации (обязательные: дата и файл – опционально, но можно проверить)
            const orgDocsResult = await pool.query('SELECT doc_type, date, date_end, file_name FROM org_documents WHERE organization_id = $1', [org.id]);
            for (const doc of orgDocsResult.rows) {
                if (!doc.date) {
                    report.push({
                        org_name: org.name,
                        section: `Документ "${doc.doc_type}"`,
                        field: 'Дата начала',
                        value: ''
                    });
                }
                if (!doc.date_end) {
                    report.push({
                        org_name: org.name,
                        section: `Документ "${doc.doc_type}"`,
                        field: 'Дата окончания',
                        value: ''
                    });
                }
                if (!doc.file_name || doc.file_name.trim() === '') {
                    report.push({
                        org_name: org.name,
                        section: `Документ "${doc.doc_type}"`,
                        field: 'Файл',
                        value: 'Не загружен'
                    });
                }
            }
            // Документы ОПО
            const opoDocsResult = await pool.query(`
                SELECT o.name as opo_name, od.doc_type, od.date, od.date_end, od.file_name
                FROM opo_documents od
                JOIN opo_objects o ON od.opo_id = o.id
                WHERE o.organization_id = $1
            `, [org.id]);
            for (const doc of opoDocsResult.rows) {
                if (!doc.date) {
                    report.push({
                        org_name: org.name,
                        section: `ОПО "${doc.opo_name || 'без названия'}", документ "${doc.doc_type}"`,
                        field: 'Дата начала',
                        value: ''
                    });
                }
                if (!doc.date_end) {
                    report.push({
                        org_name: org.name,
                        section: `ОПО "${doc.opo_name || 'без названия'}", документ "${doc.doc_type}"`,
                        field: 'Дата окончания',
                        value: ''
                    });
                }
                if (!doc.file_name || doc.file_name.trim() === '') {
                    report.push({
                        org_name: org.name,
                        section: `ОПО "${doc.opo_name || 'без названия'}", документ "${doc.doc_type}"`,
                        field: 'Файл',
                        value: 'Не загружен'
                    });
                }
            }
        }

        res.json(report);
    } catch (error) {
        console.error(error);
        res.status(500).json({ message: 'Ошибка при формировании отчёта' });
    }
};

// 3. Экспорт дампа базы данных (резервное копирование)
const { exec } = require('child_process');
const path = require('path');
const fs = require('fs');

exports.exportDatabaseDump = async (req, res) => {
    const dbName = process.env.DB_NAME;
    const dbUser = process.env.DB_USER;
    const dbHost = process.env.DB_HOST;
    const dbPort = process.env.DB_PORT;
    const dumpFile = path.join(__dirname, '../../dump.sql');
    const command = `pg_dump -U ${dbUser} -h ${dbHost} -p ${dbPort} ${dbName} > "${dumpFile}"`;

    exec(command, { env: { PGPASSWORD: process.env.DB_PASSWORD } }, (error, stdout, stderr) => {
        if (error) {
            console.error(`Ошибка pg_dump: ${error}`);
            return res.status(500).json({ message: 'Ошибка при создании дампа' });
        }
        res.download(dumpFile, `backup_${new Date().toISOString().slice(0,19)}.sql`, (err) => {
            if (err) console.error(err);
            // удаляем временный файл после отправки
            fs.unlinkSync(dumpFile);
        });
    });
};
