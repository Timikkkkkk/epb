<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Архив ЭПБ · Финальная версия (виртуализация + расширенные отчёты)</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <script src="https://cdn.sheetjs.com/xlsx-0.20.2/package/dist/xlsx.full.min.js"></script>
    <style>
        /* Стили (без русских идентификаторов) */
        * { box-sizing: border-box; margin: 0; font-family: 'Inter', sans-serif; }
        body { background: #f5f7fa; min-height: 100vh; display: flex; flex-direction: column; }
        .app { width: 100%; max-width: 1400px; margin: 0 auto; background: white; display: flex; flex-direction: column; min-height: 100vh; padding: 20px 24px; }
        h1 { font-size: 1.8rem; font-weight: 500; color: #1e2f4d; margin: 0 0 16px 0; text-align: center; }
        .toolbar { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 20px; background: #f9fafc; padding: 12px 20px; border-radius: 12px; border: 1px solid #e2e8f0; align-items: center; }
        .toolbar button, .toolbar .search-box { margin: 0; }
        .search-box { margin-left: auto; background: white; border-radius: 30px; border: 1px solid #d0d9e4; padding: 3px 3px 3px 16px; display: flex; align-items: center; }
        .search-box input { border: none; padding: 6px 10px; width: 200px; outline: none; background: transparent; }
        .user-info { display: flex; align-items: center; gap: 12px; background: #e8eff8; padding: 5px 15px; border-radius: 30px; }
        .user-info span { font-weight: 500; color: #1e3f68; }
        .table-wrapper { flex: 1; background: white; border-radius: 16px; overflow: auto; border: 1px solid #e2e8f0; position: relative; height: 100%; }
        table { width: 100%; border-collapse: collapse; min-width: 1100px; }
        th, td { padding: 12px 8px; border-bottom: 1px solid #edf2f7; border-left: 1px solid #e2e8f0; border-right: 1px solid #e2e8f0; text-align: center; vertical-align: middle; }
        #orgTable tbody tr:hover { background-color: #f0f4fa; cursor: pointer; }
        td { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 250px; }
        td.expired-docs-cell { white-space: normal; text-align: left; max-width: 300px; }
        th { background: #f8fafd; font-weight: 600; border-bottom: 2px solid #d8e1ec; cursor: pointer; position: sticky; top: 0; z-index: 10; }
        tr.selected { background-color: #ecf3fd; }
        tr.expired-row { background-color: #fff0f0; }
        .pagination { display: flex; justify-content: flex-end; gap: 16px; margin-top: 16px; align-items: center; flex-wrap: wrap; }
        .pagination-controls { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
        .modal { display: none; position: fixed; top:0; left:0; width:100%; height:100%; background: rgba(0,0,0,0.4); align-items: center; justify-content: center; z-index: 1000; }
        .modal.active { display: flex; }
        .modal-content { background: white; border-radius: 24px; max-width: 1000px; width: 95%; max-height: 90vh; overflow-y: auto; padding: 24px 28px; position: relative; }
        .modal-content.small { max-width: 500px; }
        .modal-close { position: absolute; top: 16px; right: 20px; font-size: 1.5rem; cursor: pointer; color: #8aa0b8; }
        .modal-close:hover { color: #1e3f68; }
        .form-row { margin-bottom: 16px; display: flex; flex-direction: column; }
        .form-row label { font-weight: 500; font-size: 0.85rem; color: #5a7795; margin-bottom: 4px; text-align: left; }
        .form-row input, .form-row select { padding: 10px 14px; border: 1px solid #d0d9e4; border-radius: 16px; width: 100%; }
        .form-row input.error, .form-row select.error { border-color: #b13e3e; background-color: #fff8f8; }
        .error-message { color: #b13e3e; font-size: 0.75rem; margin-top: 4px; display: none; }
        .error-message.visible { display: block; }
        .btn { padding: 10px 24px; border-radius: 30px; border: none; cursor: pointer; font-weight: 500; transition: 0.2s; display: inline-flex; align-items: center; gap: 8px; }
        .btn-primary { background: #1e3f68; color: white; }
        .btn-primary:hover { background: #0f2b48; }
        .btn-secondary { background: #e2ebf5; color: #1e3f68; }
        .btn-danger { background: #fbecec; color: #b13e3e; }
        .btn-danger:hover { background: #f8d7d7; }
        .btn-compact { padding: 8px 16px; font-size: 0.85rem; }
        .btn:disabled { opacity: 0.6; cursor: not-allowed; }
        .toast-container { position: fixed; top: 20px; right: 20px; z-index: 2000; display: flex; flex-direction: column; gap: 10px; }
        .toast { background: #1e3f68; color: white; padding: 12px 20px; border-radius: 30px; animation: slideIn 0.2s ease; }
        .toast.success { background: #1f6b1f; }
        .toast.warning { background: #b13e3e; }
        @keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
        .footer-note { margin-top: 14px; text-align: center; color: #5f7c9a; font-size: 0.85rem; }
        @media (max-width: 768px) {
            .app { padding: 12px; }
            h1 { font-size: 1.4rem; }
            .toolbar { flex-direction: column; align-items: stretch; }
            .search-box { margin-left: 0; }
            .user-info { margin-left: 0; justify-content: center; }
            th, td { padding: 8px 4px; font-size: 0.8rem; }
            .modal-content { padding: 16px; }
        }
        .opo-item, .org-doc-item, .opo-doc-item { background: #fafcfe; border-radius: 16px; padding: 16px; margin-bottom: 16px; border: 1px solid #e2ecf5; position: relative; text-align: left; }
        .remove-opo, .remove-doc { position: absolute; top: 16px; right: 16px; cursor: pointer; color: #b13e3e; font-size: 1.2rem; }
        .duration-row { display: flex; gap: 10px; margin: 8px 0; flex-wrap: wrap; align-items: center; }
        .add-doc-panel { display: flex; gap: 10px; margin-bottom: 16px; flex-wrap: wrap; }
        .expertise-item-compact { background: #f9fcff; border: 1px solid #e0eaf5; border-radius: 12px; padding: 12px 16px; margin-bottom: 8px; display: flex; justify-content: space-between; align-items: center; }
        .expired-doc-item { font-size: 0.85rem; margin-bottom: 4px; text-align: left; }
        .file-attach { border: 1px dashed #b0c6dd; border-radius: 30px; padding: 8px 14px; background: white; display: flex; justify-content: space-between; cursor: pointer; margin-top: 8px; }
        .hidden { display: none; }
        .report-table { width: 100%; border-collapse: collapse; margin-top: 16px; }
        .report-table th, .report-table td { border: 1px solid #ddd; padding: 8px; text-align: left; }
        .report-table th { background: #f8fafd; }
        .btn-collapse { position: absolute; top: 16px; right: 50px; cursor: pointer; font-size: 1.2rem; color: #8aa0b8; }
        .btn-collapse:hover { color: #1e3f68; }
    </style>
</head>
<body>
<div class="app" id="appContainer">
    <div id="mainUI" style="display: none;">
        <h1><i class="fas fa-folder-open"></i> Архив организаций и ОПО</h1>
        <div class="toolbar">
            <button id="addOrgBtn"><i class="fas fa-building"></i> Добавить организацию</button>
            <button id="exportBtn"><i class="fas fa-file-excel"></i> Экспорт</button>
            <button id="importBtn"><i class="fas fa-file-import"></i> Импорт (реестр ЗЭПБ)</button>
            <button id="backupBtn" class="btn-secondary"><i class="fas fa-database"></i> Резервное копирование</button>
            <div class="dropdown" style="position: relative;">
                <button id="reportDropdownBtn" class="btn-secondary"><i class="fas fa-chart-bar"></i> Отчёты ▼</button>
                <div id="reportDropdownMenu" style="display: none; position: absolute; top: 100%; left: 0; background: white; border: 1px solid #ddd; border-radius: 8px; z-index: 100; min-width: 220px; box-shadow: 0 4px 8px rgba(0,0,0,0.1);">
                    <button id="reportExpiredBtn" style="width: 100%; text-align: left; padding: 8px 16px; border: none; background: none; cursor: pointer;"><i class="fas fa-calendar-times"></i> Просроченные документы</button>
                    <button id="reportMonthBtn" style="width: 100%; text-align: left; padding: 8px 16px; border: none; background: none; cursor: pointer;"><i class="fas fa-calendar-week"></i> Истекают через месяц</button>
                    <button id="reportTwoMonthsBtn" style="width: 100%; text-align: left; padding: 8px 16px; border: none; background: none; cursor: pointer;"><i class="fas fa-calendar-alt"></i> Истекают через два месяца</button>
                    <hr style="margin: 4px 0;">
                    <button id="reportMissingDocsBtn" style="width: 100%; text-align: left; padding: 8px 16px; border: none; background: none; cursor: pointer;"><i class="fas fa-file-alt"></i> Организации без документов</button>
                    <button id="reportIncompleteBtn" style="width: 100%; text-align: left; padding: 8px 16px; border: none; background: none; cursor: pointer;"><i class="fas fa-exclamation-triangle"></i> Незаполненные поля</button>
                </div>
            </div>
            <div class="user-info">
                <i class="fas fa-user-circle"></i> <span id="currentUsername"></span>
                <button id="logoutBtn" class="btn-secondary btn-compact"><i class="fas fa-sign-out-alt"></i> Выйти</button>
            </div>
            <div class="search-box"><i class="fas fa-search"></i><input type="text" id="searchInput" placeholder="Поиск по названию или ИНН..."></div>
        </div>
        <div class="table-wrapper" id="tableWrapper">
            <table id="orgTable">
                <thead>
                    <tr><th data-sort="npp">№ пп</th><th data-sort="createdAt">Дата добавления</th><th data-sort="org">Организация</th><th data-sort="opoNames">ОПО</th><th data-sort="opoCount">Кол-во ОПО</th><th data-sort="expertiseCount">Кол-во ЭПБ</th><th data-sort="expiredCount">Просрочено</th><th>Документы с истекшим сроком</th></tr>
                </thead>
                <tbody id="tableBody"></tbody>
            </table>
        </div>
        <div class="pagination"><div class="pagination-info" id="paginationInfo"></div><div class="pagination-controls"><select id="itemsPerPage"><option value="5">5</option><option value="10" selected>10</option><option value="25">25</option><option value="50">50</option></select><button id="prevPage" disabled>← Пред.</button><span id="currentPageDisplay">1</span><button id="nextPage" disabled>След. →</button></div></div>
        <div class="footer-note"><i class="fas fa-database"></i> Данные на сервере PostgreSQL. Общая база. Импорт экспертиз из реестра ЗЭПБ.</div>
    </div>
</div>

<!-- Модальное окно аутентификации -->
<div id="authModal" class="modal active">
    <div class="modal-content small">
        <div class="modal-close" id="closeAuthModal">&times;</div>
        <h2 id="authModalTitle">Вход</h2>
        <div class="form-row"><label>Имя пользователя</label><input type="text" id="authUsername" autocomplete="username" placeholder="Введите имя"></div>
        <div class="form-row" id="authEmailRow" style="display: none;"><label>Email</label><input type="email" id="authEmail" autocomplete="email" placeholder="example@company.ru"></div>
        <div class="form-row"><label>Пароль</label><input type="password" id="authPassword" autocomplete="current-password" placeholder="Минимум 6 символов"></div>
        <div class="error-message" id="authError" style="display: none;"></div>
        <div class="modal-actions">
            <button class="btn btn-secondary btn-compact" id="switchAuthBtn">Регистрация</button>
            <button class="btn btn-primary" id="submitAuthBtn">Войти</button>
        </div>
    </div>
</div>

<!-- Модальное окно организации с кнопкой закрытия -->
<div id="orgModal" class="modal"><div class="modal-content"><div class="modal-close" id="closeOrgModal">&times;</div><div class="btn-collapse" id="collapseCardBtn" title="Свернуть/закрыть"><i class="fas fa-window-minimize"></i></div><h2 id="modalTitle">Организация</h2>
<div class="form-section"><h3>Основные данные</h3>
<div class="form-row"><label>Название *</label><input type="text" id="orgName" placeholder="ООО «Ромашка»"><div class="error-message" id="orgNameError"></div></div>
<div class="flex-row"><div class="form-row" style="flex:1"><label>ИНН (10-12 цифр)</label><input type="text" id="orgInn" placeholder="7701123456"><div class="error-message" id="orgInnError"></div></div>
<div class="form-row" style="flex:1"><label>Телефон</label><input type="text" id="orgPhone" placeholder="+7 (495) 123-45-67"><div class="error-message" id="orgPhoneError"></div></div></div>
<div class="form-row"><label>Email</label><input type="email" id="orgEmail" placeholder="info@example.ru"><div class="error-message" id="orgEmailError"></div></div></div>
<div class="form-section"><h3>Документы организации</h3><div class="add-doc-panel"><select id="orgDocTypeSelect"></select><button id="addOrgDocBtn" class="btn btn-compact">+ Добавить</button></div><div id="orgDocsContainer"></div></div>
<div class="form-section"><h3>Экспертизы</h3><div id="expertiseListContainer"></div><button id="addExpertiseInOrgBtn" class="btn btn-compact">+ Добавить экспертизу</button></div>
<h3>Опасные производственные объекты (ОПО)</h3><div id="opoListContainer"></div><button id="addOpoBtn" class="btn btn-compact">+ Добавить ОПО</button>
<div class="modal-actions"><button class="btn btn-secondary btn-compact" id="cancelModal">Отмена</button><button class="btn btn-danger" id="deleteOrgBtn">Удалить организацию</button><button class="btn btn-primary" id="saveOrg">Сохранить</button></div></div></div>

<!-- Модальное окно экспертизы -->
<div id="expertiseModal" class="modal"><div class="modal-content small"><div class="modal-close" id="closeExpertiseModal">&times;</div><h2 id="expertiseModalTitle">Экспертиза</h2>
<div class="form-row"><label>Организация</label><input type="text" id="expertiseOrgName" readonly style="background:#f0f4fa;"></div>
<div class="form-row"><label>Название *</label><input type="text" id="expertiseName" placeholder="Экспертиза промышленной безопасности"><div class="error-message" id="expertiseNameError"></div></div>
<div class="form-row"><label>Тип</label><select id="expertiseType"><option value="ЗС">ЗС</option><option value="ТУ">ТУ</option></select></div>
<div class="form-row"><label>Дата проведения</label><input type="date" id="expertiseDate"><div class="error-message" id="expertiseDateError"></div></div>
<div class="form-row"><label>Срок действия (лет)</label><select id="expertiseDuration"><option value="1">1</option><option value="2">2</option><option value="3">3</option><option value="4">4</option><option value="5">5</option></select></div>
<div class="form-row"><label>Ф.И.О. эксперта</label><input type="text" id="expertiseExpert" placeholder="Иванов И.И."></div>
<div class="file-attach" id="expertiseFileAttach"><span><i class="fas fa-cloud-upload-alt"></i> Прикрепить файл</span><i class="fas fa-file-pdf"></i><input type="file" id="expertiseFile" style="display:none;"></div>
<div class="file-info" id="expertiseFileInfo">Файл не выбран</div>
<div class="modal-actions"><button class="btn btn-secondary btn-compact" id="cancelExpertiseModal">Отмена</button><button class="btn btn-primary" id="saveExpertise">Сохранить</button></div></div></div>

<!-- Модальное окно подтверждения удаления -->
<div id="confirmModal" class="modal"><div class="modal-content small"><div class="modal-close" id="closeConfirmModal">&times;</div><h2>Подтверждение удаления</h2><p id="confirmMessage">Вы уверены?</p><div class="modal-actions"><button class="btn btn-secondary" id="confirmCancelBtn">Отмена</button><button class="btn btn-danger" id="confirmOkBtn">Удалить</button></div></div></div>

<!-- Модальное окно для отображения результатов отчётов -->
<div id="reportResultModal" class="modal"><div class="modal-content" style="max-width: 1000px;"><div class="modal-close" id="closeReportResultModal">&times;</div><h2 id="reportResultTitle">Результат отчёта</h2><div id="reportResultContent"></div><div class="modal-actions"><button class="btn btn-secondary" id="closeReportResultBtn">Закрыть</button><button id="exportReportExcelBtn" class="btn-primary">Экспорт в Excel</button></div></div></div>

<input type="file" id="importFileInput" accept=".xlsx,.xls" style="display:none">
<div class="toast-container" id="toastContainer"></div>

<template id="opoItemTemplate">
    <div class="opo-item"><i class="fas fa-times-circle remove-opo"></i><h4>ОПО</h4>
    <div class="form-row"><label>Название *</label><input class="opo-name" placeholder="Площадка цеха №5"><div class="error-message opo-name-error"></div></div>
    <div class="form-row"><label>Адрес</label><input class="opo-addr" placeholder="г. Москва, ул. Промышленная 12"></div>
    <div class="form-row"><label>Класс опасности *</label><select class="opo-class"><option value="">--</option><option value="I">I</option><option value="II">II</option><option value="III">III</option><option value="IV">IV</option></select><div class="error-message opo-class-error"></div></div>
    <div class="form-row"><label>Регистрационный номер</label><input class="opo-regnum" placeholder="А56-12345-2024"></div>
    <div class="opo-docs-container"></div>
    <div class="add-doc-panel"><select class="opo-doc-type-select"></select><button class="add-opo-doc-btn btn btn-compact">+ Документ</button></div></div>
</template>

<script>
(function(){
    const API_URL = 'http://localhost:5000/api';
    let token = localStorage.getItem('token');
    let currentUser = null;

    function sanitizeText(str) {
        if (!str) return '';
        return str.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }

    function createSafeElement(tag, attributes, textContent) {
        const el = document.createElement(tag);
        if (attributes) Object.keys(attributes).forEach(key => el.setAttribute(key, attributes[key]));
        if (textContent !== undefined) el.textContent = sanitizeText(textContent);
        return el;
    }

    function showToast(message, type = 'info') {
        let container = document.getElementById('toastContainer');
        if (!container) {
            container = createSafeElement('div', { id: 'toastContainer', class: 'toast-container' });
            document.body.appendChild(container);
        }
        const toast = createSafeElement('div', { class: `toast ${type}` }, message);
        container.appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
    }

    function formatDate(dateStr) {
        if (!dateStr) return '—';
        const cleanDate = dateStr.split('T')[0];
        const parts = cleanDate.split('-');
        if (parts.length === 3) return `${parts[2]}.${parts[1]}.${parts[0]}`;
        return dateStr;
    }

    function isExpired(dateStr) {
        if (!dateStr) return false;
        const cleanDate = dateStr.split('T')[0];
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        const expiry = new Date(cleanDate + 'T12:00:00');
        return expiry < today;
    }

    async function apiRequest(endpoint, options = {}) {
        const url = `${API_URL}${endpoint}`;
        const headers = { ...options.headers };
        if (token) headers['Authorization'] = `Bearer ${token}`;
        if (!(options.body instanceof FormData)) headers['Content-Type'] = 'application/json';
        const response = await fetch(url, { ...options, headers });
        if (response.status === 401) {
            localStorage.removeItem('token');
            localStorage.removeItem('username');
            token = null;
            document.getElementById('authModal').classList.add('active');
            document.getElementById('mainUI').style.display = 'none';
            throw new Error('Сессия истекла, войдите заново');
        }
        const data = await response.json();
        if (!response.ok) throw new Error(data.message || 'Ошибка запроса');
        return data;
    }

    class App {
        constructor() {
            this.elements = this.cacheElements();
            this.organizations = [];
            this.filteredOrgs = [];
            this.currentPage = 1;
            this.itemsPerPage = 10;
            this.sortField = 'npp';
            this.sortDir = 'asc';
            this.searchTerm = '';
            this.selectedOrgId = null;
            this.currentOrgForEdit = null;
            this.isLoginMode = true;
            this.rowHeight = 60;
            this.visibleRows = 20;
            this.startIndex = 0;
            this.scrollHandler = null;
            this.wrapper = document.getElementById('tableWrapper');
            this.tbody = document.getElementById('tableBody');
            this.docTypesOrg = [
                {id:'prod', title:'Производственный контроль', hasDuration:true},
                {id:'plan', title:'План мероприятий', hasDuration:true},
                {id:'dogovor', title:'Договор с АСС', hasDuration:true},
                {id:'finance', title:'Фин. средства', hasDuration:true},
                {id:'protocol', title:'Протокол аттестации', hasDuration:true},
                {id:'svidetelstvo', title:'Свидетельство ОПО', hasDuration:false},
                {id:'other', title:'Прочие', hasDuration:false}
            ];
            this.docTypesOpo = [
                {id:'ins', title:'Страховой полис', hasDuration:true},
                {id:'char', title:'Сведения характеризующие', hasDuration:false},
                {id:'expertTU', title:'Экспертиза ТУ', hasDuration:true},
                {id:'expertZS', title:'Экспертиза ЗС', hasDuration:true}
            ];
            this.init();
        }

        cacheElements() {
            return {
                mainUI: document.getElementById('mainUI'),
                authModal: document.getElementById('authModal'),
                closeAuthModal: document.getElementById('closeAuthModal'),
                authModalTitle: document.getElementById('authModalTitle'),
                authUsername: document.getElementById('authUsername'),
                authEmail: document.getElementById('authEmail'),
                authEmailRow: document.getElementById('authEmailRow'),
                authPassword: document.getElementById('authPassword'),
                authError: document.getElementById('authError'),
                switchAuthBtn: document.getElementById('switchAuthBtn'),
                submitAuthBtn: document.getElementById('submitAuthBtn'),
                logoutBtn: document.getElementById('logoutBtn'),
                currentUsername: document.getElementById('currentUsername'),
                searchInput: document.getElementById('searchInput'),
                itemsPerPage: document.getElementById('itemsPerPage'),
                prevPage: document.getElementById('prevPage'),
                nextPage: document.getElementById('nextPage'),
                currentPageDisplay: document.getElementById('currentPageDisplay'),
                paginationInfo: document.getElementById('paginationInfo'),
                tbody: document.getElementById('tableBody'),
                addOrgBtn: document.getElementById('addOrgBtn'),
                exportBtn: document.getElementById('exportBtn'),
                importBtn: document.getElementById('importBtn'),
                backupBtn: document.getElementById('backupBtn'),
                reportDropdownBtn: document.getElementById('reportDropdownBtn'),
                reportDropdownMenu: document.getElementById('reportDropdownMenu'),
                reportExpiredBtn: document.getElementById('reportExpiredBtn'),
                reportMonthBtn: document.getElementById('reportMonthBtn'),
                reportTwoMonthsBtn: document.getElementById('reportTwoMonthsBtn'),
                reportMissingDocsBtn: document.getElementById('reportMissingDocsBtn'),
                reportIncompleteBtn: document.getElementById('reportIncompleteBtn'),
                importFileInput: document.getElementById('importFileInput'),
                orgModal: document.getElementById('orgModal'),
                closeOrgModal: document.getElementById('closeOrgModal'),
                collapseCardBtn: document.getElementById('collapseCardBtn'),
